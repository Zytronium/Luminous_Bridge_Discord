# Base URL for Luminous API (no trailing slash)
LUMINOUS_API_URL=http://localhost:4000

# Credentials for the Luminous bridge bot account
# Must be an email registered in Luminous
LUMINOUS_BOT_EMAIL=example@atlasstudents.com
LUMINOUS_BOT_PASSWORD="supersecretpassword"

# Bot token
# Required Gateway Intents: Server Members Intent + Message Content Intent
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# One webhook URL per bridged channel.
# Create via: Discord channel settings → Integrations → Webhooks → New Webhook
# Variable naming convention: DISCORD_WEBHOOK_<LUMINOUS_CHANNEL_ID_UPPERCASED_DASHES_TO_UNDERSCORES>
DISCORD_WEBHOOK_CROSS_PLATFORM_TEST=https://discord.com/api/webhooks/XXXXXXXXXX/YYYYYYYYYY

# ── Tuning (optional) ──────────────────────────────────────────────────────────
# How often (in seconds) to poll Luminous for new/edited/deleted messages
# Lower = more responsive but more API calls. Default: 2
POLL_INTERVAL=2
